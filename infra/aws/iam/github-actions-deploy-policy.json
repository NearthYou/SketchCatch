{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSketchCatchEcrImagePush",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:CompleteLayerUpload",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": [
        "arn:aws:ecr:ap-northeast-2:555980271919:repository/sketchcatch-production-api",
        "arn:aws:ecr:ap-northeast-2:555980271919:repository/sketchcatch-production-web"
      ]
    },
    {
      "Sid": "AllowEcrAuthorizationForSketchCatchPush",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "AllowSketchCatchEcsServiceUpdate",
      "Effect": "Allow",
      "Action": ["ecs:DescribeServices", "ecs:UpdateService"],
      "Resource": [
        "arn:aws:ecs:ap-northeast-2:555980271919:service/sketchcatch-production-cluster/sketchcatch-production-api",
        "arn:aws:ecs:ap-northeast-2:555980271919:service/sketchcatch-production-cluster/sketchcatch-production-web"
      ]
    },
    {
      "Sid": "AllowSketchCatchTaskDefinitionDeployment",
      "Effect": "Allow",
      "Action": ["ecs:DescribeTaskDefinition", "ecs:RegisterTaskDefinition"],
      "Resource": "*"
    },
    {
      "Sid": "AllowRunMigrationWorker",
      "Effect": "Allow",
      "Action": "ecs:RunTask",
      "Resource": "arn:aws:ecs:ap-northeast-2:555980271919:task-definition/sketchcatch-production-worker:*",
      "Condition": {
        "ArnEquals": {
          "ecs:cluster": "arn:aws:ecs:ap-northeast-2:555980271919:cluster/sketchcatch-production-cluster"
        }
      }
    },
    {
      "Sid": "AllowDescribeMigrationWorker",
      "Effect": "Allow",
      "Action": "ecs:DescribeTasks",
      "Resource": "arn:aws:ecs:ap-northeast-2:555980271919:task/sketchcatch-production-cluster/*",
      "Condition": {
        "ArnEquals": {
          "ecs:cluster": "arn:aws:ecs:ap-northeast-2:555980271919:cluster/sketchcatch-production-cluster"
        }
      }
    },
    {
      "Sid": "AllowPassSketchCatchEcsTaskRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-execution",
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-task",
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-web-task",
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-worker-execution",
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-worker-task"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    },
    {
      "Sid": "AllowPreMigrationSnapshot",
      "Effect": "Allow",
      "Action": "rds:CreateDBSnapshot",
      "Resource": [
        "arn:aws:rds:ap-northeast-2:555980271919:db:database-1",
        "arn:aws:rds:ap-northeast-2:555980271919:snapshot:sketchcatch-production-pre-migration-*"
      ]
    },
    {
      "Sid": "AllowManagePreMigrationSnapshots",
      "Effect": "Allow",
      "Action": ["rds:AddTagsToResource", "rds:DeleteDBSnapshot"],
      "Resource": "arn:aws:rds:ap-northeast-2:555980271919:snapshot:sketchcatch-production-pre-migration-*"
    },
    {
      "Sid": "AllowReadPreMigrationSnapshots",
      "Effect": "Allow",
      "Action": "rds:DescribeDBSnapshots",
      "Resource": "*"
    },
    {
      "Sid": "AllowProductionAlarmSubscription",
      "Effect": "Allow",
      "Action": ["sns:ListSubscriptionsByTopic", "sns:Subscribe"],
      "Resource": "arn:aws:sns:ap-northeast-2:555980271919:SketchCatchProductionAlerts"
    },
    {
      "Sid": "AllowRuntimeTerraformStateObjectAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::sketchcatch-terraform-state-555980271919-ap-northeast-2/production/ecs-foundation/terraform.tfstate"
    },
    {
      "Sid": "AllowRuntimeTerraformStateLockAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::sketchcatch-terraform-state-555980271919-ap-northeast-2/production/ecs-foundation/terraform.tfstate.tflock"
    },
    {
      "Sid": "AllowRuntimeCacheIngressCreate",
      "Effect": "Allow",
      "Action": "ec2:AuthorizeSecurityGroupIngress",
      "Resource": [
        "arn:aws:ec2:ap-northeast-2:555980271919:security-group/sg-09d8b7030cba492b4",
        "arn:aws:ec2:ap-northeast-2:555980271919:security-group-rule/*"
      ]
    },
    {
      "Sid": "AllowRuntimeCacheIngressReadback",
      "Effect": "Allow",
      "Action": ["ec2:DescribeSecurityGroupRules", "ec2:DescribeSecurityGroups"],
      "Resource": "*"
    },
    {
      "Sid": "AllowRuntimeCacheIngressRuleTagsOnCreate",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "arn:aws:ec2:ap-northeast-2:555980271919:security-group-rule/*",
      "Condition": {
        "StringEquals": {
          "ec2:CreateAction": "AuthorizeSecurityGroupIngress"
        }
      }
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteTaskDefinitionDeregistration",
      "Effect": "Allow",
      "Action": ["ecs:DeregisterTaskDefinition"],
      "Resource": "*"
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteInlinePolicyUpdate",
      "Effect": "Allow",
      "Action": ["iam:GetRolePolicy", "iam:PutRolePolicy"],
      "Resource": [
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-task",
        "arn:aws:iam::555980271919:role/sketchcatch-production-ecs-worker-execution"
      ]
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteLoadBalancerUpdate",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:ModifyLoadBalancerAttributes",
        "elasticloadbalancing:ModifyTargetGroup",
        "elasticloadbalancing:ModifyTargetGroupAttributes"
      ],
      "Resource": [
        "arn:aws:elasticloadbalancing:ap-northeast-2:555980271919:loadbalancer/app/sketchcatch-production-ecs/*",
        "arn:aws:elasticloadbalancing:ap-northeast-2:555980271919:targetgroup/sketchcatch-production-api/*",
        "arn:aws:elasticloadbalancing:ap-northeast-2:555980271919:targetgroup/sketchcatch-production-web/*"
      ]
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteReadback",
      "Effect": "Allow",
      "Action": [
        "elasticloadbalancing:DescribeLoadBalancerAttributes",
        "elasticloadbalancing:DescribeLoadBalancers",
        "elasticloadbalancing:DescribeTags",
        "elasticloadbalancing:DescribeTargetGroupAttributes",
        "elasticloadbalancing:DescribeTargetGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteMetricFilterUpdate",
      "Effect": "Allow",
      "Action": ["logs:DescribeMetricFilters", "logs:PutMetricFilter"],
      "Resource": "arn:aws:logs:ap-northeast-2:555980271919:log-group:/sketchcatch/production/ecs/web:*"
    },
    {
      "Sid": "AllowReviewedRuntimeCompleteArtifactCorsUpdate",
      "Effect": "Allow",
      "Action": ["s3:GetBucketCORS", "s3:PutBucketCORS"],
      "Resource": "arn:aws:s3:::sketchcatch-555980271919-ap-northeast-2-an"
    }
  ]
}
