{
  "schemaVersion": 1,
  "region": "ap-northeast-2",
  "stateBucket": "sketchcatch-terraform-state-555980271919-ap-northeast-2",
  "locking": {
    "mode": "s3_lockfile",
    "useLockfile": true,
    "bucketVersioningRequired": true,
    "stateEncryptionRequired": true,
    "dynamodbLocking": "not_used"
  },
  "phase9Policy": {
    "liveImportAllowed": false,
    "liveApplyAllowed": false,
    "liveDestroyAllowed": false,
    "cloudFormationDeletionAllowed": false,
    "duplicateRemoteObjectOwnershipAllowed": false
  },
  "groups": [
    {
      "id": "runtime",
      "terraformRoot": "infra/aws/terraform",
      "backendConfig": "infra/aws/production/backend/runtime.s3.tfbackend.example",
      "backendKey": "production/ecs-foundation/terraform.tfstate",
      "risk": "operational",
      "sequence": 1,
      "policy": "Audit existing state before adding any import block; preserve current addresses and backend key.",
      "resources": [
        {
          "category": "ECS",
          "status": "state-audit-required",
          "addresses": [
            "aws_ecs_cluster.main",
            "aws_ecs_service.api",
            "aws_ecs_service.web",
            "aws_ecs_task_definition.api",
            "aws_ecs_task_definition.web"
          ]
        },
        {
          "category": "ALB",
          "status": "state-audit-required",
          "addresses": [
            "aws_lb.ecs",
            "aws_lb_target_group.api",
            "aws_lb_target_group.web",
            "aws_lb_listener.http_forward[0]",
            "aws_lb_listener.http_redirect[0]",
            "aws_lb_listener.https[0]",
            "aws_lb_listener_rule.api_http[0]",
            "aws_lb_listener_rule.api_https[0]"
          ]
        },
        {
          "category": "ECR",
          "status": "state-audit-required",
          "addresses": [
            "aws_ecr_repository.service[\"api\"]",
            "aws_ecr_repository.service[\"web\"]",
            "aws_ecr_repository.service[\"nginx\"]",
            "aws_ecr_lifecycle_policy.service[\"api\"]",
            "aws_ecr_lifecycle_policy.service[\"web\"]",
            "aws_ecr_lifecycle_policy.service[\"nginx\"]"
          ]
        },
        {
          "category": "IAM",
          "status": "state-audit-required",
          "items": [
            "ECS execution/task roles and inline policies",
            "GitHub Actions deploy OIDC role and policy",
            "production infra read-only plan OIDC role and policy",
            "EC2 runtime role and instance profile ownership check"
          ],
          "addresses": [
            "aws_iam_role.ecs_execution",
            "aws_iam_role_policy.ecs_execution",
            "aws_iam_role.ecs_task",
            "aws_iam_role_policy.ecs_task"
          ]
        },
        {
          "category": "CloudWatch",
          "status": "state-audit-required",
          "items": [
            "ECS API/web/worker/legacy nginx log groups",
            "ECS container/target/service alarms",
            "legacy EC2 application log groups and alarms ownership check"
          ],
          "addresses": [
            "aws_cloudwatch_log_group.ecs",
            "aws_cloudwatch_log_metric_filter.ecs_error",
            "aws_cloudwatch_metric_alarm.ecs_container_errors",
            "aws_cloudwatch_metric_alarm.ecs_unhealthy_hosts",
            "aws_cloudwatch_metric_alarm.ecs_service_cpu_high",
            "aws_cloudwatch_metric_alarm.ecs_service_memory_high"
          ]
        },
        {
          "category": "SecurityGroup",
          "status": "state-audit-required",
          "addresses": [
            "aws_security_group.ecs_alb",
            "aws_security_group.ecs_service",
            "aws_vpc_security_group_ingress_rule.ecs_alb_http",
            "aws_vpc_security_group_ingress_rule.ecs_alb_https",
            "aws_vpc_security_group_egress_rule.ecs_alb_to_api",
            "aws_vpc_security_group_egress_rule.ecs_alb_to_web",
            "aws_vpc_security_group_ingress_rule.ecs_service_api_from_alb",
            "aws_vpc_security_group_ingress_rule.ecs_service_web_from_alb",
            "aws_vpc_security_group_egress_rule.ecs_service_all"
          ]
        },
        {
          "category": "Route53",
          "status": "edge-state-move-required",
          "addresses": ["aws_route53_record.ecs_alias[0]"],
          "note": "Do not import the same record into edge. Prepare an approved state move or ownership handoff first."
        }
      ]
    },
    {
      "id": "edge",
      "terraformRoot": "infra/aws/production/edge",
      "backendConfig": "infra/aws/production/backend/edge.s3.tfbackend.example",
      "backendKey": "production/edge/terraform.tfstate",
      "risk": "high",
      "sequence": 2,
      "policy": "Import only after DNS TTL, certificate renewal ownership, rollback target, and zero-change plan are approved.",
      "resources": [
        {
          "category": "Route53",
          "status": "deferred",
          "items": [
            "hosted zone ownership decision",
            "production alias record",
            "certificate validation records"
          ]
        },
        {
          "category": "ACM",
          "status": "deferred",
          "items": ["production certificate", "DNS validation ownership"]
        }
      ]
    },
    {
      "id": "data",
      "terraformRoot": "infra/aws/production/data",
      "backendConfig": "infra/aws/production/backend/data.s3.tfbackend.example",
      "backendKey": "production/data/terraform.tfstate",
      "risk": "critical",
      "sequence": 3,
      "policy": "Import one service family at a time only after backups, retention, deletion protection, and restore evidence are reviewed.",
      "resources": [
        {
          "category": "S3",
          "status": "deferred",
          "items": [
            "artifact bucket",
            "versioning",
            "encryption",
            "public access block",
            "CORS",
            "lifecycle"
          ]
        },
        {
          "category": "RDS",
          "status": "deferred",
          "items": [
            "DB instance",
            "subnet group",
            "parameter group",
            "security group rules",
            "backup and deletion protection"
          ]
        },
        {
          "category": "Redis/ElastiCache",
          "status": "cloudformation-ownership-check-required",
          "items": [
            "replication group or cluster",
            "subnet group",
            "security group",
            "snapshot and maintenance settings"
          ]
        }
      ]
    },
    {
      "id": "legacy-rollback",
      "terraformRoot": "infra/aws/production/legacy-rollback",
      "backendConfig": "infra/aws/production/backend/legacy-rollback.s3.tfbackend.example",
      "backendKey": "production/legacy-rollback/terraform.tfstate",
      "risk": "high",
      "sequence": 4,
      "policy": "Keep empty until EC2 rollback retirement is approved. Never import resources still owned by CloudFormation.",
      "resources": [
        {
          "category": "EC2/SSM rollback",
          "status": "retained-not-imported",
          "items": [
            "EC2 instance",
            "instance profile",
            "security groups",
            "SSM deployment path",
            "legacy ALB/target group/listener"
          ]
        },
        {
          "category": "CloudFormation",
          "status": "retain-owner",
          "items": ["alb-https stack", "runtime-cache-elasticache stack"],
          "note": "Do not import child resources while the stack remains the owner."
        }
      ]
    }
  ]
}
