# Local development defaults only.
# Copy this file to .env and fill local values there.
# Never commit real secrets, access keys, private keys, DB passwords, or tokens.

# Runtime mode.
NODE_ENV=development

# API server.
PORT=4000
NEXT_PUBLIC_API_BASE_URL=/api

# Database.
# Required for API endpoints that read/write RDS/PostgreSQL data, including auth login,
# projects, AWS connections, and deployments.
DATABASE_URL=postgresql://sketchcatch:sketchcatch@localhost:5432/sketchcatch
DATABASE_SSL=false
RDS_ENDPOINT=

# Auth.
# Required for signup/login, access token signing, refresh token hashing, and auth cookies.
# Generate local secrets with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_TOKEN_SECRET=

# AWS defaults.
AWS_REGION=ap-northeast-2

# S3 artifact storage.
# Required for presigned upload/export flows that store diagram images, IaC files,
# generated exports, thumbnails, and release artifacts in S3.
S3_BUCKET_NAME=sketchcatch-555980271919-ap-northeast-2-an

# AWS Role connection setup.
# Required for Settings > AWS account connection and CloudFormation trust policy generation.
# This is the SketchCatch backend runtime role ARN, not the user's Terraform execution role.
# Find it in AWS Console > IAM > Roles > SketchCatchRuntimeRole > ARN.
SKETCHCATCH_AWS_CALLER_PRINCIPAL_ARN=arn:aws:iam::<SKETCHCATCH_ACCOUNT_ID>:role/SketchCatchRuntimeRole

# Required when the API signs public CloudFormation template URLs.
# Generate a different 32+ character random value from AUTH_TOKEN_SECRET.
CLOUDFORMATION_TEMPLATE_TOKEN_SECRET=

# Optional. If unset, the API still returns templateBody, but templateUrl and launchStackUrl
# may be null. Set only to a public HTTPS base URL when Quick Create links should work.
SKETCHCATCH_PUBLIC_BASE_URL=

# Local AWS credentials.
# Prefer AWS_PROFILE for local development. Do not hardcode AWS access keys unless there is
# no safer local alternative, and never commit them.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CloudWatch logs.
CLOUDWATCH_LOGS_ENABLED=false
CLOUDWATCH_LOG_GROUP_PREFIX=/sketchcatch/production

PORT=4000
NEXT_PUBLIC_API_BASE_URL=/api

OAUTH_REDIRECT_BASE_URL=http://localhost:3000

NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Do not commit real AWS credentials.
# Prefer AWS_PROFILE for local development instead of hardcoding access keys.
# AI provider keys.
OPENAI_API_KEY=
