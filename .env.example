# SketchCatch local development example.
# 이 파일을 복사해서 `.env`로 쓰세요.
# 실제 secret, AWS Access Key, DB 비밀번호, private key는 절대 커밋하지 마세요.

# -----------------------------------------------------------------------------
# 1. 실행 모드
# -----------------------------------------------------------------------------

NODE_ENV=development

# API 서버는 기본 4000번 포트에서 실행됩니다.
HOST=0.0.0.0
PORT=4000

# Web이 API로 요청을 보낼 주소입니다.
# 로컬에서는 API 서버를 4000번에 켜고, Web은 3000번에 켜는 기준입니다.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api

# Next.js rewrite가 /api 요청을 API 서버로 넘길 때 쓰는 주소입니다.
API_PROXY_TARGET=http://127.0.0.1:4000

# -----------------------------------------------------------------------------
# 2. 로컬 PostgreSQL
# -----------------------------------------------------------------------------

# infra/local/docker-compose.yml이 쓰는 로컬 DB 값입니다.
POSTGRES_USER=sketchcatch
POSTGRES_PASSWORD=sketchcatch
POSTGRES_DB=sketchcatch
POSTGRES_PORT=5432

# API와 drizzle-kit이 쓰는 DB 연결 문자열입니다.
DATABASE_URL=postgresql://sketchcatch:sketchcatch@localhost:5432/sketchcatch
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# 3. 로그인 / 토큰
# -----------------------------------------------------------------------------

# 로컬 개발용 예시 secret입니다.
# 운영이나 공유 서버에서는 반드시 다른 32자 이상 랜덤 값으로 바꾸세요.
# 새 값 생성:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_TOKEN_SECRET=local-development-auth-token-secret-change-me-32

# -----------------------------------------------------------------------------
# 4. OAuth 로그인
# -----------------------------------------------------------------------------

# 로컬 OAuth callback 기준 주소입니다.
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# 직접 채우기:
# 네이버 개발자 센터에서 발급받은 Client ID / Client Secret을 넣으세요.
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

# 직접 채우기:
# Kakao Developers에서 발급받은 REST API Key / Client Secret을 넣으세요.
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# 직접 채우기:
# GitHub OAuth App에서 발급받은 Client ID / Client Secret을 넣으세요.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 5. AWS / S3 / CloudFormation
# -----------------------------------------------------------------------------

AWS_REGION=ap-northeast-2

# 직접 채우기:
# S3 업로드, Terraform artifact 저장, export 기능을 테스트할 bucket 이름을 넣으세요.
# 팀 공용 AWS를 쓴다면 팀장이 공유한 bucket 이름을 넣고,
# 개인 AWS를 쓴다면 직접 만든 S3 bucket 이름을 넣으세요.
S3_BUCKET_NAME=

# 직접 채우기:
# AWS Role 연결 화면과 CloudFormation trust policy 생성에 필요한 값입니다.
# "사용자 AWS Role"이 아니라 SketchCatch API 서버가 실행되는 AWS Role ARN입니다.
# 형식 예시:
# arn:aws:iam::123456789012:role/SketchCatchRuntimeRole
SKETCHCATCH_AWS_CALLER_PRINCIPAL_ARN=

# CloudFormation template URL token 서명용 secret입니다.
# 로컬 개발용 예시값이며, 운영에서는 반드시 다른 32자 이상 랜덤 값으로 바꾸세요.
CLOUDFORMATION_TEMPLATE_TOKEN_SECRET=local-cloudformation-template-secret-change-me-32

# 선택 입력:
# CloudFormation Quick Create 링크를 실제로 만들려면 public HTTPS 주소를 넣으세요.
# 로컬 localhost는 AWS CloudFormation이 접근할 수 없으므로 보통 비워둡니다.
# 예: https://api.example.com
SKETCHCATCH_PUBLIC_BASE_URL=

# 선택 입력:
# 로컬에서 AWS SDK가 쓸 profile 이름입니다.
# 보통 `aws configure --profile sketchcatch-dev`로 만든 profile 이름을 넣습니다.
AWS_PROFILE=

# 되도록 비워두세요.
# 꼭 Access Key 방식으로 테스트해야 한다면 `.env`에만 넣고 커밋하지 마세요.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# -----------------------------------------------------------------------------
# 6. Terraform 실행
# -----------------------------------------------------------------------------

# 선택 입력:
# Terraform provider plugin cache를 재사용하고 싶을 때만 넣으세요.
# 비워두면 API가 OS temp directory를 사용합니다.
TF_PLUGIN_CACHE_DIR=

# -----------------------------------------------------------------------------
# 7. CloudWatch 로그
# -----------------------------------------------------------------------------

CLOUDWATCH_LOGS_ENABLED=false
CLOUDWATCH_LOG_GROUP_PREFIX=/sketchcatch/local

# -----------------------------------------------------------------------------
# 8. OpenAI / LLM 설명
# -----------------------------------------------------------------------------

# 직접 채우기:
# OpenAI 설명 보강을 실제로 쓰려면 OpenAI API key를 넣으세요.
# 비워두면 rule 기반 fallback 설명으로 동작합니다.
OPENAI_API_KEY=

# 선택 입력:
# 비워두면 API 코드의 기본 모델을 사용합니다.
OPENAI_MODEL=gpt-5.5
