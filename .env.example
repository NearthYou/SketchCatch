# SketchCatch 로컬 개발 환경 예시입니다.
# 이 파일을 복사해서 `.env`로 사용하세요.
# 실제 secret, access key, DB 비밀번호, private key는 저장소에 커밋하지 마세요.

# -----------------------------------------------------------------------------
# 1. Runtime
# -----------------------------------------------------------------------------

# 로컬 개발 기본값입니다. 운영 GitHub Actions에서는 production으로 주입됩니다.
NODE_ENV=development

# API 서버 포트입니다. 로컬 API는 기본적으로 4000번에서 실행됩니다.
PORT=4000

# Web에서 API를 호출할 기준 경로입니다.
# `/api`를 쓰면 Next.js rewrite 또는 운영 Nginx proxy를 통해 API로 전달됩니다.
NEXT_PUBLIC_API_BASE_URL=/api

# 외부 서비스가 SketchCatch에 다시 접근할 때 쓰는 공개 기준 주소입니다.
# 로컬에서는 localhost를 쓰고, 운영에서는 https://sketchcatch.net 같은 public HTTPS 주소를 사용합니다.
SKETCHCATCH_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 2. Auth
# -----------------------------------------------------------------------------

# access token 서명과 refresh token hash에 사용하는 secret입니다.
# 32자 이상 랜덤 값으로 채우세요.
# 예시 생성 명령:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# 3. Database
# -----------------------------------------------------------------------------

# 로컬 PostgreSQL 연결 문자열입니다.
# infra/local/docker-compose.yml의 기본 DB 계정과 맞춰져 있습니다.
DATABASE_URL=postgresql://sketchcatch:sketchcatch@localhost:5432/sketchcatch

# RDS처럼 SSL이 필요한 DB에 연결할 때 true로 설정합니다.
DATABASE_SSL=false

# 운영 RDS endpoint입니다. 배포 workflow에서 EC2 health/debug 용도로 사용합니다.
RDS_ENDPOINT=

# -----------------------------------------------------------------------------
# 4. AWS
# -----------------------------------------------------------------------------

# SketchCatch MVP의 기본 AWS 리전입니다.
AWS_REGION=ap-northeast-2

# 로컬에서 AWS SDK가 쓸 SSO profile 이름입니다.
# 먼저 `aws configure sso`와 `aws sso login --profile sketchcatch-dev`를 실행하세요.
# API 서버는 AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN
# 환경변수가 있으면 시작하지 않습니다.
AWS_PROFILE=sketchcatch-dev

# AWS SDK가 ~/.aws/config 파일의 profile 설정을 읽도록 합니다.
AWS_SDK_LOAD_CONFIG=1

# diagram, Terraform artifact, deployment artifact metadata 등을 저장할 S3 bucket입니다.
# public repo에는 실제 bucket 이름 대신 예시 형식만 남깁니다.
S3_BUCKET_NAME=<artifact-bucket-name>

# Docker 로그를 CloudWatch Logs로 보낼지 여부입니다.
CLOUDWATCH_LOGS_ENABLED=false

# CloudWatch Logs를 사용할 때 log group prefix입니다.
CLOUDWATCH_LOG_GROUP_PREFIX=/sketchcatch/production

# 사용자 AWS 계정의 SketchCatchTerraformExecutionRole trust policy가 신뢰할 SketchCatch caller Role ARN입니다.
# 로컬 SSO profile은 이 caller Role 권한으로 STS AssumeRole을 호출할 수 있어야 합니다.
# public repo에는 실제 AWS account ID가 포함된 ARN을 커밋하지 마세요.
SKETCHCATCH_AWS_CALLER_PRINCIPAL_ARN=arn:aws:iam::<account-id>:role/<runtime-role-name>

# CloudFormation template URL 서명에 사용하는 secret입니다.
# 32자 이상 랜덤 값으로 채우세요.
CLOUDFORMATION_TEMPLATE_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# 5. OpenAI
# -----------------------------------------------------------------------------

# LLM 설명 기능에서 사용할 OpenAI 모델입니다.
OPENAI_MODEL=gpt-5.5

# OpenAI API key입니다. 없으면 일부 LLM 기능은 fallback 또는 비활성 상태로 동작할 수 있습니다.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# 6. AI Billing Guards
# -----------------------------------------------------------------------------

# AI 호출 비용 정책입니다. AWS credit 범위에서만 쓰겠다는 운영 가드로 사용합니다.
AI_BILLING_MODE=aws_credit_only

# 하루 AI 호출 제한입니다.
AI_DAILY_CALL_LIMIT=50

# 분당 AI 호출 제한입니다.
AI_RATE_LIMIT_PER_MINUTE=10

# -----------------------------------------------------------------------------
# 7. Bedrock
# -----------------------------------------------------------------------------

# Bedrock 사용 비용이 AWS credit 정책 안에서 확인되었는지 표시합니다.
BEDROCK_CREDIT_CONFIRMED=true

# Bedrock에서 사용할 모델 ID입니다.
BEDROCK_MODEL_ID=apac.amazon.nova-pro-v1:0

# -----------------------------------------------------------------------------
# 8. Amazon Q
# -----------------------------------------------------------------------------

# Amazon Q Assistance 기능 활성화 여부입니다.
AMAZON_Q_ENABLED=false

# Amazon Q 사용 비용이 AWS credit 정책 안에서 확인되었는지 표시합니다.
AMAZON_Q_CREDIT_CONFIRMED=false

# Amazon Q application ID입니다. 기능을 활성화할 때 채우세요.
AMAZON_Q_APPLICATION_ID=

# Amazon Q 요청에 사용할 user ID입니다.
# Anonymous identity enabled application이면 비워 두세요.
AMAZON_Q_USER_ID=

# -----------------------------------------------------------------------------
# 9. Transcribe
# -----------------------------------------------------------------------------

# Voice Requirement Input을 위해 Amazon Transcribe 사용 비용이 확인되었는지 표시합니다.
TRANSCRIBE_CREDIT_CONFIRMED=false

# 음성 요구사항 입력의 기본 언어 코드입니다.
TRANSCRIBE_LANGUAGE_CODE=ko-KR

# Transcribe 입력 미디어를 임시 저장할 S3 bucket입니다.
# public repo에는 실제 bucket 이름 대신 예시 형식만 남깁니다.
TRANSCRIBE_MEDIA_BUCKET=<transcribe-media-bucket-name>

# -----------------------------------------------------------------------------
# 10. OAuth Redirect
# -----------------------------------------------------------------------------

# OAuth provider callback URL을 만들 때 쓰는 Web 기준 주소입니다.
# 로컬에서는 http://localhost:3000, 운영에서는 https://sketchcatch.net을 사용합니다.
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 11. Naver OAuth
# -----------------------------------------------------------------------------

# Naver Developers에서 발급받은 Client ID / Client Secret입니다.
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 12. Kakao OAuth
# -----------------------------------------------------------------------------

# Kakao Developers에서 발급받은 REST API Key / Client Secret입니다.
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 13. GitHub OAuth
# -----------------------------------------------------------------------------

# GitHub OAuth App에서 발급받은 Client ID / Client Secret입니다.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 14. Local-only Terraform
# -----------------------------------------------------------------------------

# 로컬 Terraform provider plugin cache 경로입니다.
# 운영에서는 EC2 host와 API container에 같은 경로를 volume mount합니다.
TF_PLUGIN_CACHE_DIR=C:\terraform-plugin-cache
