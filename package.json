{
  "name": "sketchcatch",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "docker:build": "docker build -f docker/api.Dockerfile -t sketchcatch-api:local . && docker build -f docker/web.Dockerfile -t sketchcatch-web:local . && docker build -f docker/nginx.Dockerfile -t sketchcatch-nginx:local ."
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
