{
  "name": "@sketchcatch/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "drizzle",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && esbuild src/server.ts src/db/migrate.ts src/deployment-worker.ts --bundle --platform=node --format=cjs --target=node24 --external:pg-native --outdir=dist --out-extension:.js=.cjs",
    "start": "node dist/server.cjs",
    "start:worker": "node dist/deployment-worker.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "terraform:audit:validate": "tsx ../../scripts/terraform-resource-validation-audit.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:runtime": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "3.1073.0",
    "@aws-sdk/client-bedrock-runtime": "3.1073.0",
    "@aws-sdk/client-cloudfront": "3.1073.0",
    "@aws-sdk/client-cloudwatch": "3.1073.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1073.0",
    "@aws-sdk/client-cost-explorer": "3.1073.0",
    "@aws-sdk/client-ec2": "3.1073.0",
    "@aws-sdk/client-ecs": "3.1073.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "3.1073.0",
    "@aws-sdk/client-iam": "3.1073.0",
    "@aws-sdk/client-kms": "3.1073.0",
    "@aws-sdk/client-lambda": "3.1073.0",
    "@aws-sdk/client-pricing": "3.1073.0",
    "@aws-sdk/client-qbusiness": "3.1073.0",
    "@aws-sdk/client-resource-explorer-2": "3.1073.0",
    "@aws-sdk/client-resource-groups-tagging-api": "3.1073.0",
    "@aws-sdk/client-s3": "3.1073.0",
    "@aws-sdk/client-sts": "3.1073.0",
    "@aws-sdk/client-transcribe": "3.1073.0",
    "@aws-sdk/s3-request-presigner": "3.1073.0",
    "@sketchcatch/types": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "jose": "^6.2.3",
    "openai": "^6.45.0",
    "pg": "8.22.0",
    "redis": "^6.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.25.12",
    "tsx": "4.22.4"
  }
}
