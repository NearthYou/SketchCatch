{
  "name": "@sketchcatch/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./resource-definitions": {
      "types": "./src/resource-definitions.ts",
      "default": "./src/resource-definitions.ts"
    },
    "./architecture-dependency-rules": {
      "types": "./src/architecture-dependency-rules.ts",
      "default": "./src/architecture-dependency-rules.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "devDependencies": {
    "tsx": "4.22.4"
  }
}
